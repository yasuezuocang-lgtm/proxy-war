    "openai": "^4.85.0",
    "@google/generative-ai": "^0.24.0",
    "dotenv": "^17.4.2",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.13.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
