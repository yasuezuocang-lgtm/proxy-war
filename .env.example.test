# === SPEC §9 テスト値テンプレート ===
# このファイルをコピーして `.env.test` を作成してください。
# `NODE_ENV=test npm run dev` または tsx --test 時に `.env.test` が
# `.env` の値を上書きマージします（src/config.ts loadEnvFiles 参照）。
#
#   cp .env.example.test .env.test
#
# `.env.test` は `.gitignore` 対象。テストに必要な閾値のみ上書きする想定。

# 対話
MAX_TURNS_PER_ROUND=2

# ヒアリング
MAX_HEARINGS_PER_SIDE=1
HEARING_TIMEOUT_MS=10000

# 上告
APPEAL_WINDOW_MS=5000

# セッション
SESSION_IDLE_TIMEOUT_MS=60000

# 入力収集
MAX_PROBE_QUESTIONS=1
