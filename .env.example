# Bot A (ユーザーAの代理Bot)
BOT_A_TOKEN=your-bot-a-token
BOT_A_NAME=代理Bot A

# Bot B (ユーザーBの代理Bot)
BOT_B_TOKEN=your-bot-b-token
BOT_B_NAME=代理Bot B

# 共有サーバー (Bot同士が対話する場所)
TALK_GUILD_ID=your-talk-guild-id

# LLM Provider: anthropic | openai | gemini | openrouter | groq
LLM_PROVIDER=anthropic

# API Keys (使用するプロバイダーのキーのみ設定)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# LLM Model (省略時はプロバイダーのデフォルトを使用)
LLM_MODEL=

# Data encryption key (setup時に自動生成)
ENCRYPTION_KEY=

# === SPEC §9 数値・閾値 (省略時はSPEC本番値が使われる) ===
# 対話
MAX_TURNS_PER_ROUND=8
TURN_DELAY_MS=3000
INPUT_DEBOUNCE_MS=10000

# ヒアリング
MAX_HEARINGS_PER_SIDE=2
MAX_HEARING_FOLLOWUPS=2
HEARING_TIMEOUT_MS=300000

# 上告
MAX_APPEALS=2
APPEAL_WINDOW_MS=600000

# 入力収集
MAX_PROBE_QUESTIONS=3
MIN_INPUT_LENGTH=50

# セッション
SESSION_IDLE_TIMEOUT_MS=86400000

# typing
TYPING_REFRESH_INTERVAL_MS=5000

# 暗号化
ENCRYPTION_ALGORITHM=aes-256-gcm
