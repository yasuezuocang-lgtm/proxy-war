# Bot A (ユーザーAの代理Bot)
BOT_A_TOKEN=your-bot-a-token
BOT_A_NAME=代理Bot A

# Bot B (ユーザーBの代理Bot)
BOT_B_TOKEN=your-bot-b-token
BOT_B_NAME=代理Bot B

# 共有サーバー (Bot同士が対話する場所)
TALK_GUILD_ID=your-talk-guild-id

# LLM Provider: anthropic | openai | gemini | openrouter | groq
LLM_PROVIDER=anthropic

# API Keys (使用するプロバイダーのキーのみ設定)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# LLM Model (省略時はプロバイダーのデフォルトを使用)
LLM_MODEL=

# Data encryption key (setup時に自動生成)
ENCRYPTION_KEY=
