# Discord
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id

# LLM Provider: anthropic | openai | gemini | openrouter | groq
LLM_PROVIDER=anthropic

# API Keys (使用するプロバイダーのキーのみ設定)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# LLM Model (省略時はプロバイダーのデフォルトを使用)
LLM_MODEL=

# Data encryption key (setup時に自動生成)
ENCRYPTION_KEY=
